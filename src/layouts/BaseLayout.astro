---
import { footerNavLinks, primaryNavLinks, siteDescription, siteName } from "../lib/site-config";

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogType?: "website" | "article";
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
  robots?: string;
}

const {
  title = siteName,
  description = siteDescription,
  canonical,
  ogType = "website",
  structuredData,
  robots = "index,follow"
} = Astro.props;

const siteUrl = Astro.site?.hostname === "example.com" ? undefined : Astro.site;
const structuredDataItems = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];

function toAbsoluteUrl(value?: string): string | undefined {
  if (!value) {
    return undefined;
  }

  if (/^https?:\/\//i.test(value)) {
    return value;
  }

  if (!siteUrl) {
    return undefined;
  }

  return new URL(value, siteUrl).toString();
}

const canonicalUrl = canonical
  ? toAbsoluteUrl(canonical)
  : siteUrl
    ? new URL(Astro.url.pathname, siteUrl).toString()
    : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#f0efed" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/manifest.webmanifest" />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {
      structuredDataItems.map((item) => (
        <script type="application/ld+json" set:html={JSON.stringify(item)} />
      ))
    }
    <style>
      :root {
        --bg: #f0efed;
        --bg-soft: #faf8f5;
        --panel: rgba(255, 255, 255, 0.68);
        --panel-strong: rgba(255, 255, 255, 0.88);
        --panel-border: rgba(15, 40, 98, 0.1);
        --text: #14244e;
        --muted: #5f6982;
        --accent: #51d0de;
        --accent-secondary: #bf4aa8;
        --accent-deep: #0f2862;
        --accent-neutral: #8e8e90;
        --accent-highlight: #beef00;
        --line: rgba(15, 40, 98, 0.12);
        --line-strong: rgba(15, 40, 98, 0.22);
        --shadow: 0 22px 50px rgba(15, 40, 98, 0.11);
        --shadow-soft: 0 14px 30px rgba(15, 40, 98, 0.08);
      }

      * {
        box-sizing: border-box;
      }

      html {
        font-family: "Avenir Next", "IBM Plex Sans", "Segoe UI", sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at 10% 12%, rgba(81, 208, 222, 0.34), transparent 26%),
          radial-gradient(circle at 84% 14%, rgba(191, 74, 168, 0.18), transparent 22%),
          radial-gradient(circle at 82% 76%, rgba(190, 239, 0, 0.18), transparent 18%),
          linear-gradient(180deg, #fbfaf7 0%, #f0efed 52%, #edf2f8 100%);
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-height: 100vh;
        position: relative;
        overflow-x: hidden;
      }

      body::before,
      body::after {
        content: "";
        position: fixed;
        inset: auto;
        width: 34rem;
        height: 34rem;
        border-radius: 999px;
        pointer-events: none;
        filter: blur(56px);
        opacity: 0.55;
        z-index: -1;
      }

      body::before {
        top: -10rem;
        right: -10rem;
        background: radial-gradient(circle, rgba(81, 208, 222, 0.5), transparent 64%);
        animation: drift 20s ease-in-out infinite alternate;
      }

      body::after {
        bottom: -14rem;
        left: -8rem;
        background: radial-gradient(circle, rgba(191, 74, 168, 0.18), transparent 62%);
        animation: drift 24s ease-in-out infinite alternate-reverse;
      }

      a {
        color: var(--accent-deep);
        transition:
          color 180ms ease,
          transform 180ms ease,
          border-color 180ms ease,
          background-color 180ms ease,
          box-shadow 180ms ease;
      }

      a:hover {
        color: var(--accent-secondary);
      }

      ::selection {
        background: rgba(190, 239, 0, 0.42);
        color: var(--accent-deep);
      }

      .shell {
        width: min(1120px, calc(100vw - 32px));
        margin: 0 auto;
        padding: 28px 0 88px;
      }

      .panel {
        background: var(--panel);
        border: 1px solid var(--panel-border);
        border-radius: 28px;
        padding: 26px;
        box-shadow: var(--shadow);
        backdrop-filter: blur(18px);
        position: relative;
        overflow: hidden;
        animation: rise-in 700ms cubic-bezier(0.18, 0.86, 0.32, 1) both;
      }

      .panel::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
          linear-gradient(140deg, rgba(255, 255, 255, 0.42), transparent 32%),
          radial-gradient(circle at top right, rgba(81, 208, 222, 0.12), transparent 26%);
        pointer-events: none;
      }

      .eyebrow {
        color: var(--accent-deep);
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border-radius: 999px;
        background: linear-gradient(
          135deg,
          rgba(81, 208, 222, 0.16),
          rgba(191, 74, 168, 0.08) 72%,
          rgba(190, 239, 0, 0.18)
        );
        border: 1px solid rgba(15, 40, 98, 0.1);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.78rem;
        font-weight: 700;
      }

      .muted {
        color: var(--muted);
      }

      .grid {
        display: grid;
        gap: 16px;
      }

      .cards {
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      }

      .dual-panels {
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      }

      .card {
        border: 1px solid var(--line);
        border-radius: 22px;
        padding: 18px;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.84), rgba(255, 255, 255, 0.58));
        box-shadow: var(--shadow-soft);
        position: relative;
        overflow: hidden;
      }

      .card:hover {
        transform: translateY(-3px);
        border-color: rgba(81, 208, 222, 0.28);
        box-shadow: 0 18px 32px rgba(15, 40, 98, 0.12);
      }

      a.card {
        text-decoration: none;
      }

      a.card strong {
        color: var(--accent-deep);
      }

      .card strong,
      .card b {
        display: block;
        margin-bottom: 8px;
      }

      .card p {
        margin: 0;
      }

      .link-card {
        display: grid;
        gap: 14px;
        min-height: 172px;
        align-content: space-between;
      }

      .link-card-body {
        display: grid;
        gap: 8px;
      }

      .link-card-copy {
        display: -webkit-box;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 2;
        overflow: hidden;
      }

      .link-card-cta {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 0.82rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--accent-secondary);
      }

      .link-card-cta::after {
        content: "->";
        font-size: 0.9rem;
      }

      .pill-list {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .pill {
        display: inline-flex;
        align-items: center;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 10px 14px;
        text-decoration: none;
        background: rgba(255, 255, 255, 0.74);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.65);
      }

      .pill:hover {
        transform: translateY(-1px);
        background: rgba(255, 255, 255, 0.95);
        border-color: rgba(81, 208, 222, 0.32);
      }

      .button-row {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 48px;
        padding: 0 18px;
        border-radius: 999px;
        font-weight: 700;
        text-decoration: none;
        border: 1px solid transparent;
        box-shadow: var(--shadow-soft);
      }

      .button:hover {
        transform: translateY(-2px);
      }

      .button.primary {
        background: linear-gradient(
          135deg,
          var(--accent-deep) 0%,
          var(--accent) 62%,
          var(--accent-highlight) 100%
        );
        color: #fdfdfa;
        box-shadow: 0 16px 30px rgba(81, 208, 222, 0.28);
      }

      .button.secondary {
        border-color: var(--line-strong);
        background: rgba(255, 255, 255, 0.74);
        color: var(--accent-deep);
      }

      .explorer-shell {
        display: grid;
        gap: 20px;
      }

      .explorer-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px;
      }

      .explorer-summary {
        min-width: 96px;
        text-align: right;
      }

      .explorer-summary strong {
        display: block;
        font-size: 2rem;
        line-height: 1;
        color: var(--accent-deep);
      }

      .filter-stack {
        display: grid;
        gap: 14px;
      }

      .filter-group {
        margin: 0;
        padding: 0;
        border: 0;
        min-inline-size: 0;
      }

      .filter-group legend {
        margin-bottom: 10px;
        font-size: 0.92rem;
        color: var(--muted);
        font-weight: 700;
      }

      .filter-chip {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 38px;
        padding: 0 14px;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.76);
        color: var(--text);
        font: inherit;
        cursor: pointer;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.72);
      }

      .filter-chip.is-active {
        background: var(--accent-highlight);
        color: var(--accent-deep);
        border-color: transparent;
        box-shadow: 0 12px 24px rgba(190, 239, 0, 0.2);
      }

      .page-shell {
        display: grid;
        gap: 24px;
      }

      .article-layout {
        display: grid;
        grid-template-columns: minmax(0, 1.5fr) minmax(260px, 0.78fr);
        gap: 24px;
        align-items: start;
      }

      .page-main {
        display: grid;
        gap: 20px;
        min-width: 0;
      }

      .after-stack {
        display: grid;
        gap: 20px;
      }

      .page-hero-panel {
        background:
          radial-gradient(circle at top left, rgba(81, 208, 222, 0.14), transparent 24%),
          linear-gradient(
            150deg,
            rgba(255, 255, 255, 0.9),
            rgba(255, 255, 255, 0.72) 56%,
            rgba(255, 255, 255, 0.84)
          );
      }

      .lead-panel {
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.84), rgba(255, 255, 255, 0.66)),
          rgba(255, 255, 255, 0.72);
      }

      .body-panel {
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0.62)),
          rgba(255, 255, 255, 0.72);
      }

      .page-rail {
        min-width: 0;
      }

      .rail-sticky {
        position: sticky;
        top: 104px;
        display: grid;
        gap: 16px;
      }

      .rail-panel {
        gap: 14px;
      }

      .rail-copy,
      .page-support {
        max-width: 56ch;
      }

      .rail-facts {
        margin: 0;
        display: grid;
        gap: 12px;
      }

      .rail-facts div {
        display: grid;
        gap: 4px;
        padding-top: 12px;
        border-top: 1px solid var(--line);
      }

      .rail-facts dt {
        font-size: 0.78rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .rail-facts dd {
        margin: 0;
        font-weight: 700;
        color: var(--accent-deep);
      }

      .rail-checklist,
      .toc-list {
        margin: 0;
        padding-left: 1.1rem;
        display: grid;
        gap: 10px;
        color: var(--muted);
      }

      .toc-list li {
        list-style: decimal;
      }

      .toc-list li.toc-child {
        margin-left: 0.8rem;
        list-style: lower-alpha;
      }

      .toc-list a {
        text-decoration: none;
      }

      .rail-pill-list {
        gap: 8px;
      }

      .page-header {
        display: grid;
        gap: 14px;
      }

      .page-signal-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .page-signal {
        display: inline-flex;
        align-items: center;
        min-height: 34px;
        padding: 0 12px;
        border-radius: 999px;
        background: rgba(20, 36, 78, 0.06);
        border: 1px solid rgba(15, 40, 98, 0.08);
        color: var(--accent-deep);
        font-size: 0.84rem;
        font-weight: 700;
      }

      .page-header h1 {
        max-width: 14ch;
      }

      .intro-copy,
      .section-copy {
        max-width: 72ch;
      }

      .page-updated {
        margin: 0;
        font-size: 0.92rem;
      }

      .lead-stack {
        display: grid;
        gap: 24px;
      }

      .meta-row,
      .stat-row,
      .tag-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .meta-chip,
      .tag {
        display: inline-flex;
        align-items: center;
        min-height: 32px;
        padding: 0 12px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.72);
        border: 1px solid var(--line);
        font-size: 0.92rem;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.72);
      }

      .body-copy {
        display: grid;
        gap: 0;
      }

      .body-copy > :global(*) {
        min-width: 0;
      }

      .body-copy > :global(* + *) {
        margin-top: 1rem;
      }

      .body-copy > :global(h2) {
        margin-top: 2.5rem;
        padding-top: 1rem;
        border-top: 1px solid var(--line);
      }

      .body-copy > :global(h2:first-child) {
        margin-top: 0;
        padding-top: 0;
        border-top: 0;
      }

      .body-copy > :global(h2:first-child + p) {
        font-size: 1.12rem;
        line-height: 1.8;
        color: var(--accent-deep);
        max-width: 60ch;
      }

      .body-copy > :global(h3) {
        margin-top: 1.8rem;
      }

      .body-copy > :global(p),
      .body-copy > :global(ul),
      .body-copy > :global(ol) {
        max-width: 68ch;
      }

      .body-copy > :global(ul),
      .body-copy > :global(ol) {
        padding-left: 1.2rem;
      }

      .body-copy > :global(li + li) {
        margin-top: 0.45rem;
      }

      .body-copy > :global(blockquote) {
        margin: 1.25rem 0 0;
        padding: 0.9rem 1rem;
        border-left: 4px solid rgba(81, 208, 222, 0.5);
        background: rgba(255, 255, 255, 0.62);
        border-radius: 0 18px 18px 0;
      }

      .takeaway-card {
        display: grid;
        gap: 12px;
      }

      .takeaway-index {
        width: fit-content;
      }

      .faq-list {
        display: grid;
        gap: 12px;
      }

      .faq-item {
        padding: 0;
      }

      .faq-item summary {
        list-style: none;
        cursor: pointer;
        padding: 18px 20px;
        font-weight: 700;
        color: var(--accent-deep);
      }

      .faq-item summary::-webkit-details-marker {
        display: none;
      }

      .faq-item p {
        padding: 0 20px 18px;
      }

      .faq-item[open] {
        border-color: rgba(81, 208, 222, 0.28);
      }

      .decision-card {
        display: grid;
        gap: 8px;
        background:
          linear-gradient(135deg, rgba(81, 208, 222, 0.16), rgba(190, 239, 0, 0.18)),
          rgba(255, 255, 255, 0.8);
        border-color: rgba(81, 208, 222, 0.18);
      }

      .page-type-games_like .page-hero-panel {
        background:
          radial-gradient(circle at top left, rgba(81, 208, 222, 0.2), transparent 26%),
          linear-gradient(145deg, rgba(255, 255, 255, 0.92), rgba(238, 250, 251, 0.78) 58%, rgba(255, 255, 255, 0.84));
      }

      .page-type-games_like .rail-panel h2,
      .page-type-games_like .page-signal {
        color: #0a4f63;
      }

      .page-type-best .page-hero-panel {
        background:
          radial-gradient(circle at top left, rgba(190, 239, 0, 0.18), transparent 24%),
          linear-gradient(145deg, rgba(255, 255, 255, 0.92), rgba(251, 252, 235, 0.8) 58%, rgba(255, 255, 255, 0.84));
      }

      .page-type-best .rail-panel h2,
      .page-type-best .page-signal {
        color: #456100;
      }

      .page-type-explained .page-hero-panel {
        background:
          radial-gradient(circle at top left, rgba(191, 74, 168, 0.15), transparent 24%),
          linear-gradient(145deg, rgba(255, 255, 255, 0.92), rgba(251, 240, 248, 0.8) 58%, rgba(255, 255, 255, 0.84));
      }

      .page-type-explained .rail-panel h2,
      .page-type-explained .page-signal {
        color: #8b2e79;
      }

      .page-type-feature .page-hero-panel {
        background:
          radial-gradient(circle at top left, rgba(15, 40, 98, 0.16), transparent 24%),
          linear-gradient(145deg, rgba(255, 255, 255, 0.92), rgba(236, 243, 255, 0.82) 58%, rgba(255, 255, 255, 0.84));
      }

      .page-type-feature .rail-panel h2,
      .page-type-feature .page-signal {
        color: #163f8f;
      }

      .home-flow {
        display: grid;
        gap: 24px;
      }

      .hero-layout {
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) minmax(300px, 0.9fr);
        gap: 24px;
        align-items: start;
      }

      .launchpad-panel {
        display: grid;
        gap: 16px;
      }

      .route-grid {
        display: grid;
        gap: 14px;
      }

      .route-card {
        border: 1px solid var(--line);
        border-radius: 22px;
        padding: 18px;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.84), rgba(255, 255, 255, 0.58));
        box-shadow: var(--shadow-soft);
      }

      .route-card h3 {
        margin: 6px 0 10px;
        font-size: 1.2rem;
      }

      .route-card p {
        margin: 0 0 14px;
      }

      .route-card-kicker {
        color: var(--accent-secondary);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 0.76rem;
        font-weight: 800;
      }

      .game-card,
      .explorer-card {
        display: grid;
        grid-template-columns: minmax(280px, 340px) minmax(0, 1fr);
        gap: 20px;
        align-items: stretch;
        padding: 18px;
      }

      .game-card-body {
        display: grid;
        align-content: start;
        gap: 16px;
        padding: 20px 22px;
        border-radius: 22px;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(248, 250, 253, 0.82));
        border: 1px solid rgba(15, 40, 98, 0.1);
        box-shadow:
          inset 0 1px 0 rgba(255, 255, 255, 0.86),
          0 10px 22px rgba(15, 40, 98, 0.05);
      }

      .game-list,
      .explorer-list {
        grid-template-columns: 1fr;
        gap: 18px;
      }

      .game-card-hero {
        position: relative;
        overflow: hidden;
        border-radius: 20px;
        isolation: isolate;
        height: 100%;
        min-height: 236px;
        background: linear-gradient(
          145deg,
          rgba(15, 40, 98, 0.96),
          rgba(191, 74, 168, 0.52) 58%,
          rgba(81, 208, 222, 0.52)
        );
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.16);
      }

      .game-card-hero img,
      .game-card-fallback {
        display: block;
        width: 100%;
        height: 100%;
        min-height: 236px;
      }

      .game-card-hero img {
        height: 100%;
        object-fit: cover;
      }

      .game-card-fallback {
        display: grid;
        place-items: end start;
        padding: 18px;
        min-height: 232px;
        color: white;
        font-size: 1.45rem;
        font-weight: 800;
        letter-spacing: 0.04em;
      }

      .game-card-signal-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .game-card-signal {
        display: inline-flex;
        align-items: center;
        min-height: 28px;
        padding: 0 10px;
        border-radius: 999px;
        background: rgba(81, 208, 222, 0.14);
        border: 1px solid rgba(81, 208, 222, 0.24);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.5);
        color: var(--accent-deep);
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .game-card-intro {
        display: grid;
        gap: 12px;
        padding-bottom: 16px;
        border-bottom: 1px solid rgba(15, 40, 98, 0.1);
      }

      .game-card-meta-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 12px;
      }

      .game-card-head {
        display: grid;
        gap: 6px;
      }

      .game-card-head strong {
        margin-bottom: 0;
        font-size: clamp(1.32rem, 2vw, 1.62rem);
        line-height: 1.06;
      }

      .game-card-players {
        align-self: flex-start;
        background: rgba(15, 40, 98, 0.06);
      }

      .game-card-pitch {
        font-size: 1rem;
        line-height: 1.62;
      }

      .game-stat-grid {
        margin: 0;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .game-stat-grid div {
        min-width: 112px;
        flex: 1 1 0;
        padding: 12px 14px;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.58);
        border: 1px solid rgba(15, 40, 98, 0.08);
      }

      .game-stat-grid dt {
        margin: 0 0 4px;
        font-size: 0.72rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--muted);
      }

      .game-stat-grid dd {
        margin: 0;
        color: var(--accent-deep);
        font-weight: 700;
      }

      .game-card-fit {
        font-size: 0.96rem;
        padding: 14px 16px;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.58);
        border: 1px solid rgba(15, 40, 98, 0.08);
      }

      .game-card-mechanics {
        display: grid;
        gap: 10px;
        padding: 14px 16px;
        border-radius: 18px;
        background: linear-gradient(
          135deg,
          rgba(81, 208, 222, 0.12),
          rgba(255, 255, 255, 0.76) 68%
        );
        border: 1px solid rgba(81, 208, 222, 0.18);
      }

      .game-card-label {
        display: block;
        margin-bottom: 4px;
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--accent-secondary);
        font-weight: 800;
      }

      .game-card-section-label {
        display: block;
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--accent-deep);
        font-weight: 800;
      }

      .compact-tags {
        gap: 8px;
      }

      .table-wrap {
        overflow-x: auto;
        border: 1px solid var(--line);
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.72);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.78);
      }

      .explorer-grid .card[hidden] {
        display: none;
      }

      .explorer-card {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(255, 255, 255, 0.62));
      }

      .empty-state {
        margin: 0;
        padding: 18px 20px;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.7);
        border: 1px dashed rgba(15, 40, 98, 0.16);
      }

      .comparison-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 640px;
      }

      .comparison-table th,
      .comparison-table td {
        padding: 14px 16px;
        border-bottom: 1px solid var(--line);
        text-align: left;
        vertical-align: top;
      }

      .comparison-table thead th {
        color: var(--accent-deep);
        background: linear-gradient(
          135deg,
          rgba(81, 208, 222, 0.16),
          rgba(191, 74, 168, 0.1) 78%
        );
      }

      .comparison-table tbody tr:nth-child(even) {
        background: rgba(255, 255, 255, 0.34);
      }

      .comparison-table tbody tr:last-child th,
      .comparison-table tbody tr:last-child td {
        border-bottom: 0;
      }

      h1,
      h2,
      h3 {
        line-height: 1.1;
        color: var(--accent-deep);
        font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", serif;
        letter-spacing: -0.03em;
        text-wrap: balance;
      }

      h1 {
        margin: 14px 0 10px;
        font-size: clamp(2.4rem, 5vw, 4.4rem);
        max-width: 11ch;
      }

      h2 {
        margin: 0 0 12px;
        font-size: clamp(1.4rem, 3vw, 2rem);
      }

      main > section + section,
      article > section + section {
        margin-top: 24px;
      }

      article ul,
      article ol {
        color: var(--muted);
      }

      article p {
        color: var(--muted);
        line-height: 1.72;
      }

      article h2 {
        margin-top: 0;
      }

      code {
        padding: 0.12rem 0.42rem;
        border-radius: 0.45rem;
        background: rgba(15, 40, 98, 0.08);
        color: var(--accent-deep);
        font-family: "SFMono-Regular", "Menlo", "Consolas", monospace;
        font-size: 0.92em;
      }

      header.site-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        margin-bottom: 24px;
        padding: 12px 0 4px;
      }

      .brand {
        font-weight: 800;
        text-decoration: none;
        color: var(--accent-deep);
        letter-spacing: -0.03em;
        font-size: 1.15rem;
        display: inline-flex;
        align-items: center;
        gap: 10px;
      }

      .brand::before {
        content: "";
        width: 12px;
        height: 12px;
        border-radius: 999px;
        background: linear-gradient(
          135deg,
          var(--accent) 0%,
          var(--accent-secondary) 72%,
          var(--accent-highlight) 100%
        );
        box-shadow: 0 0 0 5px rgba(81, 208, 222, 0.14);
      }

      .site-nav,
      .site-footer-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
      }

      .site-nav a,
      .site-footer-nav a {
        text-decoration: none;
        padding: 0.5rem 0.85rem;
        border-radius: 999px;
      }

      .site-nav a:hover,
      .site-footer-nav a:hover {
        background: rgba(255, 255, 255, 0.72);
        box-shadow: var(--shadow-soft);
      }

      .site-footer {
        margin-top: 28px;
        padding-top: 20px;
        border-top: 1px solid var(--line);
        display: grid;
        gap: 12px;
      }

      .hero-panel {
        padding: clamp(28px, 5vw, 46px);
        min-height: min(72vh, 520px);
        display: grid;
        align-content: end;
        gap: 14px;
        background:
          radial-gradient(circle at top left, rgba(81, 208, 222, 0.2), transparent 28%),
          radial-gradient(circle at 84% 18%, rgba(191, 74, 168, 0.15), transparent 22%),
          linear-gradient(
            145deg,
            rgba(255, 255, 255, 0.82),
            rgba(255, 255, 255, 0.55) 52%,
            rgba(255, 255, 255, 0.74)
          );
      }

      .hero-panel::after {
        content: "";
        position: absolute;
        width: min(42vw, 360px);
        height: min(42vw, 360px);
        right: -7%;
        top: -18%;
        border-radius: 44% 56% 58% 42% / 42% 38% 62% 58%;
        background: linear-gradient(
          135deg,
          rgba(81, 208, 222, 0.88),
          rgba(191, 74, 168, 0.72) 58%,
          rgba(190, 239, 0, 0.82)
        );
        opacity: 0.2;
        filter: blur(4px);
        animation: hero-swirl 18s ease-in-out infinite alternate;
        pointer-events: none;
      }

      .hero-panel > * {
        position: relative;
        z-index: 1;
      }

      .hero-panel p {
        max-width: 62ch;
        font-size: 1.04rem;
      }

      .hero-signal-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .hero-signal {
        display: inline-flex;
        align-items: center;
        min-height: 34px;
        padding: 0 12px;
        border-radius: 999px;
        background: rgba(20, 36, 78, 0.08);
        color: var(--accent-deep);
        font-size: 0.84rem;
        font-weight: 700;
        border: 1px solid rgba(15, 40, 98, 0.08);
      }

      .hero-panel .button-row {
        margin-top: 10px;
      }

      .hero-support {
        max-width: 42ch;
        font-size: 0.95rem;
      }

      @keyframes rise-in {
        from {
          opacity: 0;
          transform: translateY(14px);
        }

        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @keyframes drift {
        from {
          transform: translate3d(0, 0, 0) scale(1);
        }

        to {
          transform: translate3d(16px, -20px, 0) scale(1.06);
        }
      }

      @keyframes hero-swirl {
        from {
          transform: rotate(0deg) scale(1);
        }

        to {
          transform: rotate(18deg) scale(1.08);
        }
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }

        body::before,
        body::after,
        .hero-panel::after,
        .panel {
          animation: none;
        }

        .button:hover,
        .card:hover,
        .pill:hover {
          transform: none;
        }
      }

      @media (max-width: 720px) {
        .article-layout,
        .hero-layout {
          grid-template-columns: 1fr;
        }

        .rail-sticky {
          position: static;
        }

        header.site-header {
          flex-direction: column;
          align-items: flex-start;
        }

        .explorer-header {
          flex-direction: column;
        }

        .explorer-summary {
          text-align: left;
        }

        .hero-panel {
          min-height: auto;
        }

        .game-card,
        .explorer-card {
          grid-template-columns: 1fr;
        }

        .game-card-hero {
          height: auto;
          min-height: 0;
        }

        .game-card-hero img,
        .game-card-fallback {
          height: auto;
          min-height: 0;
          aspect-ratio: 460 / 215;
        }

        .game-card-body {
          padding: 18px;
        }

        .game-card-meta-row {
          align-items: flex-start;
        }

        .game-stat-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="site-header">
        <a class="brand" href="/">{siteName}</a>
        <nav class="site-nav muted" aria-label="Primary">
          {
            primaryNavLinks.map((link) => (
              <a href={link.href}>{link.label}</a>
            ))
          }
        </nav>
      </header>
      <slot />
      <footer class="site-footer muted">
        <div>{siteDescription}</div>
        <nav class="site-footer-nav" aria-label="Footer">
          {
            footerNavLinks.map((link) => (
              <a href={link.href}>{link.label}</a>
            ))
          }
        </nav>
      </footer>
    </div>
  </body>
</html>

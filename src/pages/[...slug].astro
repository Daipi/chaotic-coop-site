---
import { getCollection, getEntries, render } from "astro:content";
import BestTemplate from "../components/page-types/BestTemplate.astro";
import ExplainedTemplate from "../components/page-types/ExplainedTemplate.astro";
import FeatureTemplate from "../components/page-types/FeatureTemplate.astro";
import GamesLikeTemplate from "../components/page-types/GamesLikeTemplate.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { pageHref, sortPagesByIds } from "../lib/page-utils";

export async function getStaticPaths() {
  const pages = await getCollection("pages", ({ data }) => !data.draft);

  return pages.map((page) => ({
    params: { slug: page.id },
    props: { page }
  }));
}

const { page } = Astro.props;
const allPages = await getCollection("pages", ({ data }) => !data.draft);
const mentionedGames = await getEntries(page.data.gamesMentioned);
const relatedPages = sortPagesByIds(
  allPages.filter((candidate) => candidate.id !== page.id),
  page.data.relatedPages
);
const { Content, headings } = await render(page);
const hasRealSite = Boolean(Astro.site) && Astro.site.hostname !== "example.com";
const pageUrl = hasRealSite ? new URL(pageHref(page), Astro.site).toString() : undefined;
const keywords = [page.data.targetKeyword, ...page.data.secondaryKeywords]
  .filter(Boolean)
  .join(", ");
const webPageSchema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: page.data.metaTitle,
  headline: page.data.title,
  description: page.data.metaDescription,
  inLanguage: "en"
};

if (pageUrl) {
  webPageSchema.url = pageUrl;
}

if (page.data.updatedAt) {
  webPageSchema.dateModified = page.data.updatedAt.toISOString();
}

if (keywords) {
  webPageSchema.keywords = keywords;
}

if (mentionedGames.length > 0) {
  webPageSchema.about = mentionedGames.map((game) => ({
    "@type": "VideoGame",
    name: game.data.name
  }));
}

const structuredData: Array<Record<string, unknown>> = [webPageSchema];

if (page.data.faq.length > 0) {
  structuredData.push({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: page.data.faq.map((item) => ({
      "@type": "Question",
      name: item.q,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.a
      }
    }))
  });
}
---

<BaseLayout
  title={page.data.metaTitle}
  description={page.data.metaDescription}
  canonical={pageHref(page)}
  ogType="article"
  structuredData={structuredData}
>
  {
    page.data.type === "games_like" ? (
      <GamesLikeTemplate
        page={page}
        games={mentionedGames}
        relatedPages={relatedPages}
        headings={headings}
        featuredGame={(await getEntries([page.data.featuredGame]))[0]}
        shortlistGames={await getEntries(page.data.shortlistGames)}
        comparisonFields={page.data.comparisonFields}
      >
        <Content />
      </GamesLikeTemplate>
    ) : page.data.type === "best" ? (
      <BestTemplate
        page={page}
        games={mentionedGames}
        relatedPages={relatedPages}
        headings={headings}
        quickPickGames={await getEntries(page.data.quickPickGames)}
        comparisonFields={page.data.comparisonFields}
        rankingLabel={page.data.rankingLabel}
      >
        <Content />
      </BestTemplate>
    ) : page.data.type === "explained" ? (
      <ExplainedTemplate
        page={page}
        games={mentionedGames}
        relatedPages={relatedPages}
        headings={headings}
        exampleGames={await getEntries(page.data.exampleGames)}
        glossaryLabel={page.data.glossaryLabel}
        conceptPills={page.data.conceptPills}
      >
        <Content />
      </ExplainedTemplate>
    ) : (
      <FeatureTemplate
        page={page}
        games={mentionedGames}
        relatedPages={relatedPages}
        headings={headings}
        comparedGames={await getEntries(page.data.comparedGames)}
        comparisonFields={page.data.comparisonFields}
        winnerSummary={page.data.winnerSummary}
      >
        <Content />
      </FeatureTemplate>
    )
  }
</BaseLayout>

---
import FaqSection from "../common/FaqSection.astro";
import KeyTakeaways from "../common/KeyTakeaways.astro";
import PageRail from "../common/PageRail.astro";
import PageHeader from "../common/PageHeader.astro";
import RelatedPagesSection from "../common/RelatedPagesSection.astro";
import type { GameEntry, PageEntry, PageHeading } from "../../types/page-props";

export interface Props {
  page: PageEntry;
  relatedPages: PageEntry[];
  headings: PageHeading[];
  railGames?: GameEntry[];
  afterBeforeBody?: boolean;
  takeawaysAfterBody?: boolean;
}

const {
  page,
  relatedPages,
  headings,
  railGames = [],
  afterBeforeBody = false,
  takeawaysAfterBody = false
} = Astro.props;
const hasLead = Astro.slots.has("lead");
const hasAfter = Astro.slots.has("after");
---

<div class={`article-layout page-type-${page.data.type}`}>
  <div class="page-main">
    <section class="panel page-hero-panel">
      <PageHeader page={page} />
    </section>

    {
      hasLead && (
        <section class="panel lead-panel">
          <div class="lead-stack">
            <slot name="lead" />
          </div>
        </section>
      )
    }

    {hasAfter && afterBeforeBody && <div class="after-stack"><slot name="after" /></div>}

    {
      page.data.keyTakeaways.length > 0 && !takeawaysAfterBody && (
        <section class="panel">
          <KeyTakeaways items={page.data.keyTakeaways} />
        </section>
      )
    }

    <article class="panel body-panel">
      <section class="body-copy">
        <slot />
      </section>
    </article>

    {hasAfter && !afterBeforeBody && <div class="after-stack"><slot name="after" /></div>}

    {
      page.data.keyTakeaways.length > 0 && takeawaysAfterBody && (
        <section class="panel">
          <KeyTakeaways items={page.data.keyTakeaways} />
        </section>
      )
    }

    {
      page.data.faq.length > 0 && (
        <section class="panel">
          <FaqSection items={page.data.faq} />
        </section>
      )
    }

    {
      relatedPages.length > 0 && (
        <section class="panel">
          <RelatedPagesSection pages={relatedPages} />
        </section>
      )
    }
  </div>

  <PageRail page={page} headings={headings} relatedPages={relatedPages} railGames={railGames} />
</div>

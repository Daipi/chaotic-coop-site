---
import GameExplorer from "../common/GameExplorer.astro";
import LinkCardGrid from "../common/LinkCardGrid.astro";
import PillLinks from "../common/PillLinks.astro";
import SectionPanel from "../common/SectionPanel.astro";
import HomeHero from "./HomeHero.astro";
import type { HomeTemplateProps } from "../../types/page-props";

export interface Props {
  page: HomeTemplateProps["page"];
  games: HomeTemplateProps["games"];
}

const { page, games } = Astro.props;
const routeGroups = [
  {
    eyebrow: "By Game",
    title: "Start from the exact game your group just played",
    description:
      "Use the title-led routes when the question is literally 'what do we play after this?'",
    items: page.shortcuts
  },
  {
    eyebrow: "By Vibe",
    title: "Start from the energy you want tonight",
    description:
      "Use these mood-led routes when you care more about tone, fear, price, or chaos than a specific game name.",
    items: page.browseByVibe
  },
  {
    eyebrow: "By Question",
    title: "Start with the concept or the close call",
    description:
      "Use explainers and comparisons when the language is fuzzy or your group is split between similar picks.",
    items: [...page.explainers, ...page.comparisons]
  }
];
---

<main class="home-flow">
  <section class="hero-layout">
    <HomeHero hero={page.hero} />

    <section class="panel launchpad-panel">
      <div class="eyebrow">Choose Your Route</div>
      <h2>Start the way your group actually talks</h2>
      <p class="section-copy">
        Some readers arrive with a title, some with a vibe, and some with a comparison question.
        The first screen should help all three without feeling like a sitemap dump.
      </p>
      <div class="route-grid">
        {
          routeGroups.map((group) => (
            <article class="route-card">
              <div class="route-card-kicker">{group.eyebrow}</div>
              <h3>{group.title}</h3>
              <p class="muted">{group.description}</p>
              <PillLinks items={group.items} />
            </article>
          ))
        }
      </div>
    </section>
  </section>

  <section class="grid dual-panels">
    <SectionPanel eyebrow="Start Here" title="Open the fastest route for tonight's decision">
      <LinkCardGrid items={page.topPicks} />
    </SectionPanel>

    <SectionPanel eyebrow="Next Problem" title="Handle the most common tie-breakers next">
      <LinkCardGrid items={page.fresh} />
    </SectionPanel>
  </section>

  <GameExplorer
    title="Browse the Current Co-Op Pool"
    description="Scan the pool as full game rows first, then narrow it by tone, fear level, party size, and mechanics."
    games={games}
    filterKeys={["tone", "horrorLevel", "players", "physicsChaos", "proximityChat", "sessionLength"]}
    emptyMessage="Try clearing one of the filters to bring more games back into view."
    variant="home"
  />

  <section class="grid dual-panels">
    <SectionPanel eyebrow="Explainers" title="Decode the terms before you bounce">
      <LinkCardGrid items={page.explainers} />
    </SectionPanel>
    <SectionPanel eyebrow="Comparisons" title="Break the tie between close picks">
      <LinkCardGrid items={page.comparisons} />
    </SectionPanel>
  </section>
</main>

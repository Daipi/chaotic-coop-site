---
export interface Props {
  items: { q: string; a: string }[];
}

const { items } = Astro.props;
---

{
  items.length > 0 && (
    <section>
      <h2>FAQ</h2>
      <div class="grid">
        {items.map((item) => (
          <div class="card">
            <strong>{item.q}</strong>
            <p class="muted">{item.a}</p>
          </div>
        ))}
      </div>
    </section>
  )
}


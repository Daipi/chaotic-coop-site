---
export interface Props {
  items: { q: string; a: string }[];
}

const { items } = Astro.props;
---

{
  items.length > 0 && (
    <section>
      <h2>Questions Readers Still Ask</h2>
      <div class="faq-list">
        {items.map((item) => (
          <details class="card faq-item">
            <summary>{item.q}</summary>
            <p class="muted">{item.a}</p>
          </details>
        ))}
      </div>
    </section>
  )
}

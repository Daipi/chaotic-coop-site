---
import { formatDate, pageTypeLabel } from "../../lib/page-utils";
import type { PageEntry } from "../../types/page-props";

export interface Props {
  page: PageEntry;
}

const { page } = Astro.props;
const updatedLabel = formatDate(page.data.updatedAt);
const intentSupport = {
  recommendation: "Find the shortest route to the right game for tonight.",
  comparison: "See which pick fits your group's mood, fear tolerance, and session style.",
  definition: "Get the term in plain English, then jump straight to the clearest examples."
}[page.data.searchIntent];
const typeSignals = {
  games_like: ["Closest matches", "Fast substitutes"],
  best: ["Ranked shortlist", "Broader discovery"],
  explained: ["Plain-English definition", "Examples first"],
  feature: ["Head-to-head call", "Decision support"]
}[page.data.type];
---

<header class="page-header">
  <div class="eyebrow">{pageTypeLabel(page.data.type)}</div>
  <h1>{page.data.title}</h1>
  <p class="muted intro-copy">{page.data.intro}</p>
  <div class="page-signal-row">
    {typeSignals.map((signal) => (
      <span class="page-signal">{signal}</span>
    ))}
  </div>
  <p class="page-support">{intentSupport}</p>
  {updatedLabel && <p class="page-updated muted">Updated {updatedLabel}</p>}
</header>

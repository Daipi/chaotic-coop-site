---
import type { SiteLink } from "../../types/page-props";

export interface Props {
  items: SiteLink[];
}

const { items } = Astro.props;
---

<div class="grid cards">
  {
    items.map((item) => (
      <a class="card link-card" href={item.href}>
        <div class="link-card-body">
          <strong>{item.label}</strong>
          {item.description && <p class="muted link-card-copy">{item.description}</p>}
        </div>
        <span class="link-card-cta">Open page</span>
      </a>
    ))
  }
</div>

---
export interface Props {
  items: string[];
}

const { items } = Astro.props;
---

{
  items.length > 0 && (
    <section>
      <h2>What to Know First</h2>
      <div class="grid cards">
        {items.map((item, index) => (
          <div class="card takeaway-card">
            <span class="meta-chip takeaway-index">0{index + 1}</span>
            <strong>{item}</strong>
          </div>
        ))}
      </div>
    </section>
  )
}

---
export interface Props {
  items: string[];
}

const { items } = Astro.props;
---

{
  items.length > 0 && (
    <section>
      <h2>Key Takeaways</h2>
      <div class="grid cards">
        {items.map((item) => (
          <div class="card">
            <strong>{item}</strong>
          </div>
        ))}
      </div>
    </section>
  )
}

